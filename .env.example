NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string. Local Mongo works for development only.
MONGODB_URI=mongodb://127.0.0.1:27017/blog-cms
DB_REQUIRED=false
MONGO_MAX_RETRIES=3
MONGO_RETRY_DELAY_MS=1000

# Auth. Use long random values in production.
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN_SECONDS=3600
SESSION_EXPIRES_IN_MS=3600000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Comma-separate multiple frontend origins if needed.
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# Request limits.
MAX_JSON_BODY_SIZE=1mb
MAX_IMAGE_SIZE_BYTES=2097152
